{
  "name": "todolist-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "E2E todolist: TC-B1-5591000 blocking gate, TC-HP-3291000 HP dev queue smoke",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage --coverageReporters=json-summary"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "!lib/**/*.test.js",
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "json-summary"
    ]
  }
}
